{
	"name": "bun-template",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"prepare": "bun x lefthook install",
		"proto:generate": "buf generate",
		"start": "bun src/index.ts"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.0",
		"envalid": "^8.1.1"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.70.0",
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"@types/bun": "^1.3.13",
		"lefthook": "^2.1.6",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"typescript": "^6.0.3"
	}
}
